{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "openrouter": {
      "models": {
        "~nvidia/nemotron-3-ultra-550b-a55b:free": {}
      }
    }
  },
  "agent": {
    "build": {
      "mode": "primary",
      "model": "openrouter/nvidia/nemotron-3-ultra-550b-a55b:free",
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "allow",
          "rm *": "deny",
          "rmdir *": "deny",
          "git clean *": "deny",
          "sudo *": "deny"
        }
      }
    }
  }
}
